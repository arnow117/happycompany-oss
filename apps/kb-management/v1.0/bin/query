#!/usr/bin/env bash
set -euo pipefail

WORKDIR="${WORKDIR:-.}"
KB_DIR="${WORKDIR}/knowledge"
CARDS_DIR="${KB_DIR}/cards"

if [ ! -d "${CARDS_DIR}" ]; then
  echo "No knowledge cards found at ${CARDS_DIR}"
  exit 0
fi

count=$(find "${CARDS_DIR}" -name "*.md" | wc -l | tr -d ' ')
echo "Knowledge base: ${count} card(s) in ${CARDS_DIR}"

if [ -f "${KB_DIR}/index.md" ]; then
  echo ""
  echo "--- Index ---"
  head -20 "${KB_DIR}/index.md"
fi
