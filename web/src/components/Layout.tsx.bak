  borderRadius: 'var(--radius-sm)',
  transition: 'background var(--transition-fast) var(--ease-out-expo), color var(--transition-fast) var(--ease-out-expo)',
  background: 'none',
  border: 'none',
  color: 'var(--color-on-dark-soft)',
  fontSize: '12px',
  fontFamily: 'var(--font-body)',
  cursor: 'pointer',
  padding: '4px 0',
  textAlign: 'left',
  borderRadius: 'var(--radius-sm)',
  transition: 'all var(--transition-fast) var(--ease-out-expo)',
};

