  textAlign: 'left',
  display: 'flex',
  alignItems: 'center',
  gap: '8px',
  width: 'fit-content',
  borderRadius: 'var(--radius-sm)',
  transition: 'all var(--transition-fast) var(--ease-out-expo)',
};

