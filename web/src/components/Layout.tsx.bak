  background: 'none',
  border: 'none',
  padding: '4px',
  cursor: 'pointer',
  display: 'flex',
  alignItems: 'center',
  justifyContent: 'center',
  borderRadius: 'var(--radius-sm)',
  transition: background var(--transition-fast) var(--ease-out-expo), color var(--transition-fast) var(--ease-out-expo),
};

menuButton[':hover'] = {
  background: 'var(--color-surface-dark-soft)',
};

